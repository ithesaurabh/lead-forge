{
  "name": "lead-forge",
  "version": "1.0.0",
  "description": "LeadForge is a modular Lead Management and Product CRM built with TypeScript, Express, Prisma, MySQL, and Paseto. It provides role-based access control (RBAC), lead lifecycle management, product catalog management, category organization, email automation, and audit-ready architecture for modern business workflows.",
  "homepage": "https://github.com/ithesaurabh/lead-forge#readme",
  "bugs": {
    "url": "https://github.com/ithesaurabh/lead-forge/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ithesaurabh/lead-forge.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon  --watch .env  --watch src --ext ts --exec tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "generate": "node cheat_sheets/generate-module.ts",
    "seed:permissions": "tsx src/database/seeds/permission.seed.ts"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "nodemon": "^3.1.14",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "crypto": "^1.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "multer": "^2.2.0",
    "paseto": "^3.1.4",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  }
}
