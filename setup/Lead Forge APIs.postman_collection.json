{
  "info": {
    "_postman_id": "588a7cd8-8336-4194-a7c2-48d0bdb4597a",
    "name": "Lead Forge APIs",
    "description": "LeadForge is a modern Lead Management and Product CRM REST API built with TypeScript, Express, Prisma, and MySQL. It provides secure PASETO-based authentication, Role-Based Access Control (RBAC), and a modular architecture for building scalable business applications. The API supports comprehensive management of users, roles, permissions, products, categories, and customer leads, with consistent JSON responses and robust request validation using Zod. Rich HTML content is sanitized before storage, ensuring security without compromising flexibility. Designed with maintainability and extensibility in mind, LeadForge offers a clean, developer-friendly interface for integrating CRM functionality into web, mobile, and enterprise applications.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "55172637",
    "_collection_link": "https://go.postman.co/collection/55172637-588a7cd8-8336-4194-a7c2-48d0bdb4597a?source=collection_link"
